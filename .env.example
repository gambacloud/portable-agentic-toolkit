# Copy this file to .env and fill in values.
# .env is git-ignored; never commit real secrets.

# ── Chainlit auth (auto-generated by bootstrap if missing) ───────────────────
# CHAINLIT_AUTH_SECRET=your_random_secret_here

# ── Bot identity ─────────────────────────────────────────────────────────────
# BOT_NAME=Gambabot

# ── App mode ─────────────────────────────────────────────────────────────────
# SINGLE (default): one local user, no header auth required.
# MULTI: identifies users by X-User-Email header; unauthenticated sessions run
#        in Guest Mode (history and persistence disabled).
# APP_MODE=SINGLE

# ── Database ──────────────────────────────────────────────────────────────────
# DB_PATH=gambabot.db

# ── API server ───────────────────────────────────────────────────────────────
# API_PORT=8001

# ── Ollama ───────────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── MCP server API keys ──────────────────────────────────────────────────────
# BRAVE_API_KEY=your_key_here
# GITHUB_TOKEN=your_token_here
