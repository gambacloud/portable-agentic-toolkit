# Copy this file to .env and fill in values.
# .env is git-ignored; never commit real secrets.

# ── Bot identity ─────────────────────────────────────────────────────────────
# BOT_NAME=Gambabot

# ── Database ──────────────────────────────────────────────────────────────────
# DB_PATH=gambabot.db

# ── Ollama ───────────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── MCP server API keys ──────────────────────────────────────────────────────
# BRAVE_API_KEY=your_key_here
# GITHUB_TOKEN=your_token_here
